# syntax=docker/dockerfile:1
# Бэкенд API (Node.js).
# Docker-контекст в compose: корень Parking_lot.
FROM node:20-alpine

WORKDIR /app

# Ставим зависимости для сборки/запуска бэкенда
COPY backend-app/package*.json ./
RUN --mount=type=cache,target=/root/.npm \
    npm ci --legacy-peer-deps

# Копируем исходники бэкенда (код из backend/)
COPY backend/ ./backend/

# Сборка TypeScript в backend/dist
RUN npx tsc -p backend/tsconfig.json

EXPOSE 3001

CMD ["node", "backend/dist/app.js"]
